@model IEnumerable<SystemGestionReservation.Application.DTOs.Client.ClientDto>
@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people"></i> Clients</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Nouveau client
    </a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="terme" value="@ViewBag.Terme"
               class="form-control" placeholder="Rechercher par nom, identité, téléphone..." />
        <button class="btn btn-outline-secondary" type="submit">
            <i class="bi bi-search"></i> Rechercher
        </button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-primary">
        <tr>
            <th>Nom complet</th>
            <th>N° Identité</th>
            <th>Téléphone</th>
            <th>Email</th>
            <th>Statut</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.Prenom @client.Nom</td>
                <td>@client.NumeroIdentite</td>
                <td>@client.Telephone</td>
                <td>@client.Email</td>
                <td>
                    @if (client.EstActif)
                    {
                        <span class="badge bg-success">Actif</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactif</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@client.Id"
                           class="btn btn-sm btn-info text-white">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Edit" asp-route-id="@client.Id"
                           class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-controller="Reservations" asp-action="Index"
                           asp-route-clientId="@client.Id"
                           class="btn btn-sm btn-secondary">
                        <i class="bi bi-calendar"></i> Réservations
                    </a>
                    <form asp-action="Desactiver" asp-route-id="@client.Id"
                          method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Désactiver ce client ?')">
                            <i class="bi bi-person-x"></i>
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>