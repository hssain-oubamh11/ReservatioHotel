@model SystemGestionReservation.Application.DTOs.Facture.FactureDto
@{
    ViewData["Title"] = $"Facture #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-receipt"></i> Facture #@Model.Id</h2>
    <button onclick="window.print()" class="btn btn-outline-secondary">
        <i class="bi bi-printer"></i> Imprimer
    </button>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <p><strong>Client :</strong> @Model.ClientNomComplet</p>
                <p><strong>Chambre :</strong> @Model.ChambreNumero</p>
            </div>
            <div class="col-md-6">
                <p><strong>Arrivée :</strong> @Model.DateArrivee.ToString("dd/MM/yyyy")</p>
                <p><strong>Départ :</strong> @Model.DateDepart.ToString("dd/MM/yyyy")</p>
                <p><strong>Nuits :</strong> @Model.NombreNuits</p>
                <p><strong>Émise le :</strong> @Model.DateEmission.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
    </div>
</div>

<table class="table table-bordered">
    <thead class="table-light">
        <tr>
            <th>Description</th>
            <th class="text-center">Qté</th>
            <th class="text-end">Prix unitaire</th>
            <th class="text-end">Sous-total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ligne in Model.Lignes)
        {
            <tr>
                <td>@ligne.Description</td>
                <td class="text-center">@ligne.Quantite</td>
                <td class="text-end">@ligne.PrixUnitaire.ToString("C")</td>
                <td class="text-end">@ligne.SousTotal.ToString("C")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="table-primary fw-bold">
            <td colspan="3" class="text-end">TOTAL</td>
            <td class="text-end">@Model.MontantTotal.ToString("C")</td>
        </tr>
    </tfoot>
</table>

<div class="mt-3">
    @if (Model.EstPayee)
    {
        <span class="badge bg-success fs-6">
            <i class="bi bi-check-circle"></i> Payée
        </span>
    }
    else
    {
        <span class="badge bg-warning text-dark fs-6">
            <i class="bi bi-clock"></i> En attente de paiement
        </span>
    }
</div>