@model IEnumerable<SystemGestionReservation.Application.DTOs.Reservation.ReservationDto>
@using SystemGestionReservation.Core.Enums
@{
    ViewData["Title"] = "Réservations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-calendar"></i> Réservations — @ViewBag.ClientNom</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-calendar-plus"></i> Nouvelle réservation
    </a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-primary">
        <tr>
            <th>Chambre</th>
            <th>Arrivée</th>
            <th>Départ</th>
            <th>Nuits</th>
            <th>Personnes</th>
            <th>Statut</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.ChambreNumero</td>
                <td>@r.DateArrivee.ToString("dd/MM/yyyy")</td>
                <td>@r.DateDepart.ToString("dd/MM/yyyy")</td>
                <td>@r.NombreNuits</td>
                <td>@r.NombrePersonnes</td>
                <td>
                    @{
                        var badgeClass = r.Statut switch
                        {
                            StatutReservation.Confirmee => "bg-success",
                            StatutReservation.CheckInEffectue => "bg-primary",
                            StatutReservation.CheckOutEffectue => "bg-secondary",
                            StatutReservation.Annulee => "bg-danger",
                            _ => "bg-warning text-dark"
                        };
                    }
                    <span class="badge @badgeClass">@r.Statut</span>
                </td>
                <td>
                    @if (r.Statut == StatutReservation.Confirmee || r.Statut == StatutReservation.EnAttente)
                    {
                        <form asp-action="CheckIn" asp-route-id="@r.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="clientId" value="@ViewBag.ClientId" />
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="bi bi-box-arrow-in-right"></i> Check-in
                            </button>
                        </form>
                        <form asp-action="Annuler" asp-route-id="@r.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="clientId" value="@ViewBag.ClientId" />
                            <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('Annuler cette réservation ?')">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </form>
                    }
                    @if (r.Statut == StatutReservation.CheckInEffectue)
                    {
                        <form asp-action="CheckOut" asp-route-id="@r.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="clientId" value="@ViewBag.ClientId" />
                            <button type="submit" class="btn btn-sm btn-success">
                                <i class="bi bi-box-arrow-right"></i> Check-out
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>