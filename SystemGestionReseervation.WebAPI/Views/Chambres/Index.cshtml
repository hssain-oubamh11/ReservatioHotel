@model IEnumerable<SystemGestionReservation.Application.DTOs.Chambre.ChambreDto>
@{
    ViewData["Title"] = "Chambres";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-door-open"></i> Chambres</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nouvelle chambre
    </a>
</div>

<!-- Filtre disponibilité -->
<div class="card mb-4">
    <div class="card-header bg-light">
        <i class="bi bi-search"></i> Vérifier la disponibilité
    </div>
    <div class="card-body">
        <form asp-action="Disponibles" method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Date d'arrivée</label>
                <input type="date" name="dateArrivee" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Date de départ</label>
                <input type="date" name="dateDepart" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Type</label>
                <select name="type" class="form-select">
                    <option value="">Tous les types</option>
                    <option value="Simple">Simple</option>
                    <option value="Double">Double</option>
                    <option value="Suite">Suite</option>
                    <option value="Familiale">Familiale</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Liste des chambres -->
<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var chambre in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center
                    @(chambre.EstActive ? "bg-success" : "bg-secondary") text-white">
                    <span class="fw-bold">
                        <i class="bi bi-door-open"></i> Chambre N° @chambre.Numero
                    </span>
                    <span class="badge bg-white text-dark">@chambre.Type</span>
                </div>
                <div class="card-body">
                    <table class="table table-borderless table-sm mb-2">
                        <tr>
                            <td class="text-muted">Étage</td>
                            <td><strong>@chambre.Etage</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Capacité</td>
                            <td><strong>@chambre.CapaciteAccueil personne(s)</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Description</td>
                            <td>@chambre.Description</td>
                        </tr>
                    </table>

                    @if (chambre.Equipements.Any())
                    {
                        <div class="mb-2">
                            @foreach (var eq in chambre.Equipements)
                            {
                                <span class="badge bg-info text-dark me-1">
                                    <i class="bi bi-check"></i> @eq
                                </span>
                            }
                        </div>
                    }
                </div>
                <div class="card-footer bg-white d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@chambre.Id"
                           class="btn btn-sm btn-warning flex-fill">
                        <i class="bi bi-pencil"></i> Modifier
                    </a>
                    <form asp-action="Desactiver" asp-route-id="@chambre.Id"
                          method="post" class="flex-fill">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger w-100"
                                onclick="return confirm('Désactiver cette chambre ?')">
                            <i class="bi bi-x-circle"></i> Désactiver
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">
        <i class="bi bi-info-circle"></i> Aucune chambre active trouvée.
    </div>
}